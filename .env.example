# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ─── Groq (alternativa gratuita a Anthropic) ─────────────────────────────────
GROQ_API_KEY=gsk_xxx

# ─── Upstash Redis (antifraude en tiempo real) ───────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ─── Bot de Telegram ─────────────────────────────────────────────────────────
# Obtener de @BotFather en Telegram
TELEGRAM_BOT_TOKEN=xxx:xxx

# ─── Resend (notificaciones por correo) ──────────────────────────────────────
# Gratis hasta 3,000 correos/mes en resend.com
RESEND_API_KEY=re_xxx

# ─── Seguridad ────────────────────────────────────────────────────────────────
# Clave secreta para hash SHA-256 de códigos de premio
# Usar mínimo 64 caracteres aleatorios en producción
HASH_SECRET=una_clave_secreta_larga_de_al_menos_64_caracteres_aqui_1234567890

# ─── App ─────────────────────────────────────────────────────────────────────
# URL pública del proyecto (sin trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
